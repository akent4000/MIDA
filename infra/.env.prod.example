# Production environment template — copy to .env.prod and fill in real values.
# DO NOT commit the populated .env.prod (it contains secrets).
#
# IMPORTANT: keep POSTGRES_PASSWORD in sync with the password embedded in
# DATABASE_URL — they refer to the same credential.

# Postgres (in-compose; consumed by both the postgres container and backend)
POSTGRES_USER=mida
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=mida

# Database — service name `postgres` resolves on the mida-net network
DATABASE_URL=postgresql+psycopg2://mida:CHANGE_ME@postgres:5432/mida

# Redis / Celery broker — service name `redis` on mida-net
REDIS_URL=redis://redis:6379/0

# MinIO — runs in docker-compose.minio.yml on the same mida-net network
MINIO_ENDPOINT=mida-minio:9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=mida-studies
MINIO_SECURE=false

# ML — ONNX backend with INT8 weights deployed by deploy-model.yml
INFERENCE_BACKEND=onnx
PNEUMONIA_WEIGHTS_PATH=/srv/models/single-int8.onnx
PNEUMONIA_ENSEMBLE_PATHS=/srv/models/fold1-int8.onnx,/srv/models/fold2-int8.onnx,/srv/models/fold3-int8.onnx,/srv/models/fold4-int8.onnx,/srv/models/fold5-int8.onnx

ENVIRONMENT=production
