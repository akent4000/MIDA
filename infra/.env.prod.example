# Production environment template — copy to .env.prod and fill in real values.
# DO NOT commit the populated .env.prod (it contains secrets).
#
# IMPORTANT: keep POSTGRES_PASSWORD in sync with the password embedded in
# DATABASE_URL — they refer to the same credential.

# Postgres (in-compose; consumed by both the postgres container and backend)
POSTGRES_USER=mida
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=mida

# Database — service name `postgres` resolves on the mida-net network
DATABASE_URL=postgresql+psycopg2://mida:CHANGE_ME@postgres:5432/mida

# Redis / Celery broker — service name `redis` on mida-net
REDIS_URL=redis://redis:6379/0

# MinIO — shared endpoint for both studies and model weights
MINIO_ENDPOINT=mida-minio:9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=mida-studies
MINIO_SECURE=false

# MinIO — models bucket (weights downloaded lazily on first inference)
MINIO_MODELS_BUCKET=mida-models
WEIGHTS_CACHE_DIR=/tmp/mida-weights

# ML — ONNX backend; weights are pulled from MinIO automatically, no scp needed.
# Keys are object paths inside MINIO_MODELS_BUCKET.
INFERENCE_BACKEND=onnx
PNEUMONIA_WEIGHTS_MINIO_KEY=onnx/single-int8.onnx
PNEUMONIA_ENSEMBLE_MINIO_KEYS=onnx/fold1-int8.onnx,onnx/fold2-int8.onnx,onnx/fold3-int8.onnx,onnx/fold4-int8.onnx,onnx/fold5-int8.onnx

ENVIRONMENT=production
