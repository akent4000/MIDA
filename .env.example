# Copy to .env and fill in. Used by backend.app.core.config.Settings.

# --- Database ---
DATABASE_URL=postgresql+psycopg2://mida:mida@localhost:5432/mida

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0

# --- MinIO (S3-compatible object storage) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=mida-studies
MINIO_SECURE=false

# --- ML inference ---
# pytorch (dev box) | onnx (prod server)
INFERENCE_BACKEND=pytorch

# Dev: local .pt checkpoint path (PyTorch backend). Leave empty to skip auto-load.
PNEUMONIA_WEIGHTS_PATH=

# Prod: MinIO object keys inside MINIO_MODELS_BUCKET (downloaded lazily on first use).
# Leave empty on dev.
PNEUMONIA_WEIGHTS_MINIO_KEY=
PNEUMONIA_ENSEMBLE_MINIO_KEYS=

ENVIRONMENT=development
