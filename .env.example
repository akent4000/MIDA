# Copy to .env and fill in. Used by backend.app.core.config.Settings.

# --- Database ---
DATABASE_URL=postgresql+psycopg2://mira:mira@localhost:5432/mira

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0

# --- MinIO (S3-compatible object storage) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=mida-studies
MINIO_SECURE=false

# --- ML inference ---
# pytorch (dev box) | onnx (prod server)
INFERENCE_BACKEND=pytorch
# Path to a .pt checkpoint. Leave empty to skip auto-load (inference will fail
# until weights are loaded, but other endpoints work).
PNEUMONIA_WEIGHTS_PATH=

ENVIRONMENT=development
